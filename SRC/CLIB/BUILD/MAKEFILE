######################################################################
#
#	Makefile for CLIB.IRL
#
######################################################################

.SUFFIXES: .irl .asm .rel

BIN	= z80emu
AS	= $(BIN) as
OL	= $(BIN) ol a



OBJS	= startup sscanf fscanf scanf xxscn sprintf cprintf \
	fprintf printf xfputc frmts intdos settime

OBJS1	= setdate gettime getdate getdisk abswrit absread setdisk \
	setarg diei inp outp root2 fread fwrite fgets

OBJS2	= fgetc fputc fputs fputc1 ungetc fgetc1 cgets fclose \
	fopen freopen fdopen fheap clearerr fsetpos gets

OBJS3	= fgetpos fseek ftell fflush realloc calloc malloc free \
	bsearch qsort strtol atoi div rand strtok

OBJS4	= strstr strspn strupr strlwr strrchr strlen strpbrk \
	strcspn inrange strchr strncmp strcmp strncat

OBJS5	= strcat strncpy strcpy memcmp memmove memcpy memset \
	movmem memchr rename getenv putenv sysenv ioctl

OBJS6	= unlink mkdir rmdir isatty perror strerr chdir getcwd \
	tell seek ltell lseek write read open

OBJS7	= errno isprint isgraph isalpha ispunct iscntrl isspace \
	isxdigit isalnum isascii islower isupper

OBJS8	= isdigit toupper tolower xtcty kbhit gotoxy home \
	clrscr cputs getche getch putch setjmp sleep

OBJS9	= sbrk puts bdos cpshd srab srihb srnhb slab slhb \
	dvbab dvihd min max abs dvnhd mulab

OBJS10	= mulhd sauhl lauhl ffirst fnext hex32 hex16 hex8 \
	msinit msshow mshide dec8 dec16 dec32

OBJS11	= msstat msgstat msspos mssgpos msybnd msxbnd msscur \
	mstcur msgcur msgsens mssens mshard msvmode msref

clib.irl: startup.rel sscanf.rel fscanf.rel scanf.rel xxscn.rel sprintf.rel \
  cprintf.rel fprintf.rel printf.rel xfputc.rel frmts.rel intdos.rel \
  settime.rel setdate.rel gettime.rel getdate.rel getdisk.rel \
  abswrit.rel absread.rel setdisk.rel setarg.rel diei.rel inp.rel \
  outp.rel root2.rel fread.rel fwrite.rel fgets.rel fgetc.rel fputc.rel \
  fputs.rel fputc1.rel ungetc.rel fgetc1.rel gets.rel fclose.rel \
  fopen.rel freopen.rel fdopen.rel fheap.rel clearerr.rel fsetpos.rel \
  fgetpos.rel fseek.rel ftell.rel fflush.rel realloc.rel calloc.rel \
  malloc.rel free.rel bsearch.rel qsort.rel strtol.rel atoi.rel div.rel \
  rand.rel strtok.rel strstr.rel strspn.rel strupr.rel strlwr.rel \
  strrchr.rel strlen.rel strpbrk.rel strcspn.rel inrange.rel strchr.rel \
  strncmp.rel strcmp.rel strncat.rel strcat.rel strncpy.rel strcpy.rel \
  memcmp.rel memmove.rel memcpy.rel memset.rel movmem.rel memchr.rel \
  rename.rel getenv.rel putenv.rel sysenv.rel ioctl.rel unlink.rel \
  mkdir.rel rmdir.rel isatty.rel perror.rel strerr.rel chdir.rel \
  getcwd.rel tell.rel seek.rel ltell.rel lseek.rel write.rel read.rel \
  open.rel errno.rel isprint.rel isgraph.rel isalpha.rel ispunct.rel \
  iscntrl.rel isspace.rel isxdigit.rel isalnum.rel isascii.rel \
  islower.rel isupper.rel isdigit.rel toupper.rel tolower.rel xtcty.rel \
  kbhit.rel cgets.rel gotoxy.rel home.rel clrscr.rel cputs.rel \
  getche.rel getch.rel putch.rel setjmp.rel sleep.rel sbrk.rel puts.rel \
  bdos.rel cpshd.rel srab.rel srihb.rel srnhb.rel slab.rel slhb.rel \
  dvbab.rel dvihd.rel min.rel max.rel abs.rel dvnhd.rel mulab.rel \
  mulhd.rel sauhl.rel lauhl.rel ffirst.rel fnext.rel msinit.rel \
  msshow.rel mshide.rel msstat.rel msgstat.rel msspos.rel mssgpos.rel \
  msybnd.rel msxbnd.rel msscur.rel mstcur.rel msgcur.rel msgsens.rel \
  mssens.rel mshard.rel msvmode.rel msref.rel \
  hex32.rel hex16.rel hex8.rel dec8.rel dec16.rel dec32.rel

	$(OL) CLIB.IRL $(OBJS)
	$(OL) CLIB.IRL $(OBJS1)
	$(OL) CLIB.IRL $(OBJS2)
	$(OL) CLIB.IRL $(OBJS3)
	$(OL) CLIB.IRL $(OBJS4)
	$(OL) CLIB.IRL $(OBJS5)
	$(OL) CLIB.IRL $(OBJS6)
	$(OL) CLIB.IRL $(OBJS7)
	$(OL) CLIB.IRL $(OBJS8)
	$(OL) CLIB.IRL $(OBJS9)
	$(OL) CLIB.IRL $(OBJS10)
	$(OL) CLIB.IRL $(OBJS11)

